---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class={`w-full py-8 ${className}`} aria-hidden="true">
  <svg class="w-full h-6" viewBox="0 0 1200 24" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path
      d="M0 12 Q100 4 200 14 T400 8 T600 16 T800 6 T1000 14 T1200 10"
      stroke="currentColor"
      stroke-width="1.5"
      fill="none"
      class="text-stone dark:text-campfire-border"
    />
    <path
      d="M0 16 Q150 8 300 18 T500 10 T700 18 T900 8 T1100 16 T1200 14"
      stroke="currentColor"
      stroke-width="0.75"
      fill="none"
      class="text-stone/60 dark:text-campfire-border/60"
    />
  </svg>
</div>
