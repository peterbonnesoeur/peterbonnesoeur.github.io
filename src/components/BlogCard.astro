---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="group block p-6 bg-warm-white dark:bg-campfire rounded-2xl border border-stone dark:border-campfire-border hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
>
  <time class="text-xs font-mono text-graphite dark:text-dim">{formattedDate}</time>
  <h3 class="font-heading text-xl text-slate dark:text-moonstone mt-2 mb-2 group-hover:text-trail-orange dark:group-hover:text-trail-orange-dark transition-colors">
    {title}
  </h3>
  <p class="text-sm text-graphite dark:text-dim leading-relaxed line-clamp-3 mb-4">{description}</p>
  <div class="flex flex-wrap gap-1.5">
    {tags.map(tag => (
      <span class="px-2 py-0.5 text-[11px] rounded-full bg-topo-blue/10 text-topo-blue dark:bg-topo-blue-dark/10 dark:text-topo-blue-dark border border-topo-blue/20 dark:border-topo-blue-dark/20">
        {tag}
      </span>
    ))}
  </div>
</a>
