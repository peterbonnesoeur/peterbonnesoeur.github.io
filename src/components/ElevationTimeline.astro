---
import TopoDivider from './TopoDivider.astro';
import resumeData from '../data/resume.json';

interface TimelineEntry {
  title: string;
  company?: string;
  institution?: string;
  url?: string;
  location?: string;
  period: string;
  sortYear: number;
  elevation: number;
  type: 'education' | 'work';
  bullets?: string[];
  description?: string;
}

const experience = resumeData.experience as TimelineEntry[];
const education = resumeData.education as TimelineEntry[];

const allEntries: TimelineEntry[] = [
  ...education.map(e => ({ ...e, type: 'education' as const })),
  ...experience.map(e => ({ ...e, type: 'work' as const })),
].sort((a, b) => a.sortYear - b.sortYear);

const maxElevation = Math.max(...allEntries.map(e => e.elevation));
const minElevation = Math.min(...allEntries.map(e => e.elevation));

const svgWidth = 1000;
const svgHeight = 320;
const padding = { top: 40, bottom: 70, left: 60, right: 60 };
const plotWidth = svgWidth - padding.left - padding.right;
const plotHeight = svgHeight - padding.top - padding.bottom;

function scaleX(index: number): number {
  return padding.left + (index / (allEntries.length - 1)) * plotWidth;
}

function scaleY(elevation: number): number {
  const normalized = (elevation - minElevation) / (maxElevation - minElevation);
  return padding.top + plotHeight - normalized * plotHeight;
}

const points = allEntries.map((entry, i) => ({
  x: scaleX(i),
  y: scaleY(entry.elevation),
  ...entry,
}));

// Build filled area path
let pathD = `M ${points[0].x} ${svgHeight - padding.bottom}`;
pathD += ` L ${points[0].x} ${points[0].y}`;
for (let i = 1; i < points.length; i++) {
  const prev = points[i - 1];
  const curr = points[i];
  const cpx1 = prev.x + (curr.x - prev.x) * 0.4;
  const cpx2 = prev.x + (curr.x - prev.x) * 0.6;
  pathD += ` C ${cpx1} ${prev.y}, ${cpx2} ${curr.y}, ${curr.x} ${curr.y}`;
}
pathD += ` L ${points[points.length - 1].x} ${svgHeight - padding.bottom} Z`;

// Build trail line path
let lineD = `M ${points[0].x} ${points[0].y}`;
for (let i = 1; i < points.length; i++) {
  const prev = points[i - 1];
  const curr = points[i];
  const cpx1 = prev.x + (curr.x - prev.x) * 0.4;
  const cpx2 = prev.x + (curr.x - prev.x) * 0.6;
  lineD += ` C ${cpx1} ${prev.y}, ${cpx2} ${curr.y}, ${curr.x} ${curr.y}`;
}

// Find the boundary index where education ends and work starts
const lastEduIndex = allEntries.reduce((acc, e, i) => e.type === 'education' ? i : acc, 0);

/**
 * Convert **text** to <strong> in a string.
 */
function renderBold(text: string): string {
  return text.replace(/\*\*(.+?)\*\*/g, '<strong class="text-slate dark:text-moonstone font-semibold">$1</strong>');
}
---

<section id="work" class="max-w-6xl mx-auto px-6 py-24">
  <TopoDivider />

  <h2 class="text-3xl md:text-4xl font-heading text-slate dark:text-moonstone mb-4">The Trail</h2>
  <p class="text-graphite dark:text-dim mb-4">A career elevation profile — click any peak to explore.</p>

  <!-- Legend -->
  <div class="flex items-center gap-6 mb-8 text-sm">
    <div class="flex items-center gap-2">
      <span class="w-3 h-3 rounded-full bg-forest-green dark:bg-forest-green-dark"></span>
      <span class="text-graphite dark:text-dim">Education</span>
    </div>
    <div class="flex items-center gap-2">
      <span class="w-3 h-3 rounded-full bg-trail-orange dark:bg-trail-orange-dark"></span>
      <span class="text-graphite dark:text-dim">Work</span>
    </div>
  </div>

  <!-- SVG Elevation Chart -->
  <div class="relative w-full overflow-x-auto mb-16">
    <svg viewBox={`0 0 ${svgWidth} ${svgHeight}`} class="w-full min-w-[700px] h-auto" xmlns="http://www.w3.org/2000/svg">
      <!-- Grid lines -->
      {[0.25, 0.5, 0.75].map(frac => {
        const y = padding.top + plotHeight * (1 - frac);
        return <line x1={padding.left} y1={y} x2={svgWidth - padding.right} y2={y} stroke="currentColor" stroke-dasharray="4 4" class="text-stone/40 dark:text-campfire-border/40" />;
      })}

      <!-- Education / Work zone backgrounds -->
      {lastEduIndex < allEntries.length - 1 && (
        <>
          <rect
            x={padding.left}
            y={padding.top - 10}
            width={scaleX(lastEduIndex + 0.5) - padding.left}
            height={plotHeight + 20}
            rx="8"
            class="fill-forest-green/[0.04] dark:fill-forest-green-dark/[0.04]"
          />
          <rect
            x={scaleX(lastEduIndex + 0.5)}
            y={padding.top - 10}
            width={svgWidth - padding.right - scaleX(lastEduIndex + 0.5)}
            height={plotHeight + 20}
            rx="8"
            class="fill-trail-orange/[0.04] dark:fill-trail-orange-dark/[0.04]"
          />
          <text
            x={(padding.left + scaleX(lastEduIndex + 0.5)) / 2}
            y={padding.top - 2}
            text-anchor="middle"
            class="text-[9px] uppercase tracking-wider fill-forest-green/50 dark:fill-forest-green-dark/50 font-medium"
          >
            Education
          </text>
          <text
            x={(scaleX(lastEduIndex + 0.5) + svgWidth - padding.right) / 2}
            y={padding.top - 2}
            text-anchor="middle"
            class="text-[9px] uppercase tracking-wider fill-trail-orange/50 dark:fill-trail-orange-dark/50 font-medium"
          >
            Professional
          </text>
        </>
      )}

      <!-- Filled area -->
      <path d={pathD} class="fill-trail-orange/10 dark:fill-trail-orange-dark/10" />

      <!-- Trail line -->
      <path
        d={lineD}
        fill="none"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="stroke-trail-orange dark:stroke-trail-orange-dark"
        id="trail-path"
      />

      <!-- Data points and labels -->
      {points.map((point, i) => {
        const isEdu = point.type === 'education';
        const dotFill = isEdu
          ? 'fill-forest-green dark:fill-forest-green-dark'
          : 'fill-trail-orange dark:fill-trail-orange-dark';
        const hoverFill = isEdu
          ? 'hover:fill-forest-green/10 dark:hover:fill-forest-green-dark/10'
          : 'hover:fill-trail-orange/10 dark:hover:fill-trail-orange-dark/10';

        return (
          <g class="cursor-pointer group" data-index={i}>
            <circle
              cx={point.x}
              cy={point.y}
              r="7"
              class={`${dotFill} stroke-parchment dark:stroke-night`}
              stroke-width="3"
            />
            <circle
              cx={point.x}
              cy={point.y}
              r="14"
              fill="transparent"
              class={`${hoverFill} transition-colors`}
              data-peak={i}
            />
            {/* Elevation label */}
            <text
              x={point.x}
              y={point.y - 18}
              text-anchor="middle"
              class="text-[10px] font-mono fill-graphite dark:fill-dim pointer-events-none"
            >
              {point.elevation}m
            </text>
            {/* Year below baseline */}
            <text
              x={point.x}
              y={svgHeight - padding.bottom + 18}
              text-anchor="middle"
              class="text-[9px] fill-graphite dark:fill-dim pointer-events-none font-mono"
            >
              {point.sortYear}
            </text>
            {/* Company/institution name */}
            <text
              x={point.x}
              y={svgHeight - padding.bottom + 32}
              text-anchor="middle"
              class={`text-[10px] font-medium pointer-events-none ${isEdu ? 'fill-forest-green dark:fill-forest-green-dark' : 'fill-slate dark:fill-moonstone'}`}
            >
              {point.company || point.institution || ''}
            </text>
          </g>
        );
      })}

      <!-- Y-axis label -->
      <text x="16" y={svgHeight / 2} text-anchor="middle" transform={`rotate(-90, 16, ${svgHeight / 2})`} class="text-[10px] fill-graphite dark:fill-dim font-mono">
        career altitude (m)
      </text>
    </svg>
  </div>

  <!-- Detail cards — Education -->
  <h3 class="text-xl font-heading text-forest-green dark:text-forest-green-dark mb-4 flex items-center gap-2">
    <span class="w-3 h-3 rounded-full bg-forest-green dark:bg-forest-green-dark"></span>
    Education
  </h3>
  <div class="grid md:grid-cols-2 gap-6 mb-12" id="timeline-education">
    {allEntries.filter(e => e.type === 'education').map((entry, _i) => {
      const globalIndex = allEntries.indexOf(entry);
      return (
        <div
          class="timeline-card p-6 bg-warm-white dark:bg-campfire rounded-2xl border-l-4 border-forest-green dark:border-forest-green-dark border border-stone dark:border-campfire-border transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
          data-card={globalIndex}
        >
          <div class="flex items-start justify-between gap-4 mb-3">
            <div>
              <h3 class="font-heading text-lg text-slate dark:text-moonstone">{entry.title}</h3>
              <p class="text-sm text-graphite dark:text-dim">
                <a href={entry.url} target="_blank" rel="noopener" class="text-forest-green hover:underline dark:text-forest-green-dark">
                  {entry.institution}
                </a>
                {entry.location ? ` · ${entry.location}` : ''}
              </p>
            </div>
            <span class="shrink-0 px-2 py-1 text-xs font-mono bg-parchment dark:bg-night rounded text-graphite dark:text-dim border border-stone dark:border-campfire-border">
              {entry.period}
            </span>
          </div>
          {entry.description && (
            <p class="text-sm text-graphite dark:text-dim" set:html={renderBold(entry.description)} />
          )}
        </div>
      );
    })}
  </div>

  <!-- Detail cards — Work -->
  <h3 class="text-xl font-heading text-trail-orange dark:text-trail-orange-dark mb-4 flex items-center gap-2">
    <span class="w-3 h-3 rounded-full bg-trail-orange dark:bg-trail-orange-dark"></span>
    Professional Experience
  </h3>
  <div class="grid md:grid-cols-2 gap-6" id="timeline-work">
    {allEntries.filter(e => e.type === 'work').map((entry, _i) => {
      const globalIndex = allEntries.indexOf(entry);
      return (
        <div
          class="timeline-card p-6 bg-warm-white dark:bg-campfire rounded-2xl border-l-4 border-trail-orange dark:border-trail-orange-dark border border-stone dark:border-campfire-border transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
          data-card={globalIndex}
        >
          <div class="flex items-start justify-between gap-4 mb-3">
            <div>
              <h3 class="font-heading text-lg text-slate dark:text-moonstone">{entry.title}</h3>
              <p class="text-sm text-graphite dark:text-dim">
                <a href={entry.url} target="_blank" rel="noopener" class="text-trail-orange hover:underline dark:text-trail-orange-dark">
                  {entry.company}
                </a>
                {entry.location ? ` · ${entry.location}` : ''}
              </p>
            </div>
            <span class="shrink-0 px-2 py-1 text-xs font-mono bg-parchment dark:bg-night rounded text-graphite dark:text-dim border border-stone dark:border-campfire-border">
              {entry.period}
            </span>
          </div>

          {entry.bullets && entry.bullets.length > 0 && (
            <ul class="space-y-1.5 mt-3">
              {entry.bullets.map(bullet => (
                <li class="text-sm text-graphite dark:text-dim flex gap-2">
                  <span class="text-trail-orange dark:text-trail-orange-dark mt-0.5 shrink-0">&#9650;</span>
                  <span set:html={renderBold(bullet)} />
                </li>
              ))}
            </ul>
          )}
        </div>
      );
    })}
  </div>
</section>

<script is:inline>
  document.querySelectorAll('[data-peak]').forEach(el => {
    el.addEventListener('click', () => {
      const idx = el.getAttribute('data-peak');
      const card = document.querySelector(`[data-card="${idx}"]`);
      if (!card) return;
      card.scrollIntoView({ behavior: 'smooth', block: 'center' });
      card.classList.add('ring-2', 'ring-trail-orange');
      setTimeout(() => card.classList.remove('ring-2', 'ring-trail-orange'), 2000);
    });
  });
</script>
