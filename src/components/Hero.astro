---
import TopoBackground from './TopoBackground.astro';

let elevation = 408;
try {
  const res = await fetch('https://api.open-meteo.com/v1/elevation?latitude=47.3769&longitude=8.5417');
  const data = await res.json();
  if (data.elevation?.[0]) {
    elevation = Math.round(data.elevation[0]);
  }
} catch {
  // fallback to default Zürich elevation
}

const trailMarkers = [
  { stat: 'Led a DS team', label: 'acquired by Similarweb' },
  { stat: '4 ML products', label: 'running daily in prod' },
  { stat: 'Published', label: 'ICRA 2020' },
  { stat: '0 → 1', label: 'AI for fintech' },
];
---

<section id="hero" class="relative min-h-[90vh] flex flex-col items-center justify-center text-center px-6 overflow-hidden">
  <TopoBackground />

  <div class="relative z-10 max-w-3xl mx-auto space-y-6">
    <h1 class="text-5xl md:text-7xl font-heading text-slate dark:text-moonstone leading-tight">
      Maxime Bonnesoeur
    </h1>

    <p class="text-xl md:text-2xl text-trail-orange dark:text-trail-orange-dark font-heading">
      Just a nerd on the run.
    </p>

    <p class="text-base md:text-lg text-graphite dark:text-dim max-w-xl mx-auto leading-relaxed">
      I build AI systems with AI, from LLM pipelines to a <a href="https://toilet-radar.ch" target="_blank" rel="noopener" class="text-trail-orange hover:underline dark:text-trail-orange-dark">toilet finder for Switzerland</a>.
      Currently building fintech infrastructure at <a href="https://synthexhq.com/" target="_blank" rel="noopener" class="text-trail-orange hover:underline dark:text-trail-orange-dark">Synthex</a> in Zürich.
    </p>

    <!-- Trail markers -->
    <div class="flex flex-wrap justify-center gap-4 pt-4">
      {trailMarkers.map(marker => (
        <div class="px-4 py-2 rounded-xl border border-stone dark:border-campfire-border bg-warm-white/60 dark:bg-campfire/60 backdrop-blur-sm">
          <span class="block text-lg font-mono font-semibold text-trail-orange dark:text-trail-orange-dark">{marker.stat}</span>
          <span class="block text-[11px] uppercase tracking-wider text-graphite dark:text-dim">{marker.label}</span>
        </div>
      ))}
    </div>

    <a
      href="#featured"
      class="inline-flex items-center gap-2 px-6 py-3 mt-4 text-sm font-medium text-warm-white bg-trail-orange hover:bg-trail-orange-hover rounded-full transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5"
    >
      See what I've been up to
      <svg class="w-4 h-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </a>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-xs text-graphite/60 dark:text-dim/60 font-mono tracking-wider">
    &#9472;&#9472;&#9472; current elevation: {elevation}m (Zürich) &#9472;&#9472;&#9472;
  </div>
</section>
