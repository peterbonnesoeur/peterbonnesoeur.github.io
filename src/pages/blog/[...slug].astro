---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopoDivider from '../../components/TopoDivider.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${post.data.title} — Maxime Bonnesoeur`} description={post.data.description}>
  <article class="max-w-3xl mx-auto px-6 py-24">
    <a href="/blog" class="inline-flex items-center gap-2 text-sm text-graphite dark:text-dim hover:text-trail-orange dark:hover:text-trail-orange-dark transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Back to blog
    </a>

    <header class="mb-12">
      <time class="text-sm font-mono text-graphite dark:text-dim">{formattedDate}</time>
      <h1 class="text-4xl md:text-5xl font-heading text-slate dark:text-moonstone mt-3 mb-4">{post.data.title}</h1>
      <div class="flex flex-wrap gap-2">
        {post.data.tags.map((tag: string) => (
          <span class="px-2 py-0.5 text-xs rounded-full bg-topo-blue/10 text-topo-blue dark:bg-topo-blue-dark/10 dark:text-topo-blue-dark border border-topo-blue/20 dark:border-topo-blue-dark/20">
            {tag}
          </span>
        ))}
      </div>
    </header>

    <TopoDivider />

    <div class="prose prose-lg max-w-none
      prose-headings:font-heading prose-headings:text-slate dark:prose-headings:text-moonstone
      prose-p:text-graphite dark:prose-p:text-dim
      prose-a:text-trail-orange dark:prose-a:text-trail-orange-dark prose-a:no-underline hover:prose-a:underline
      prose-strong:text-slate dark:prose-strong:text-moonstone
      prose-code:text-sm prose-code:bg-warm-white dark:prose-code:bg-campfire prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-night prose-pre:rounded-xl
      prose-li:text-graphite dark:prose-li:text-dim
      prose-blockquote:border-l-trail-orange dark:prose-blockquote:border-l-trail-orange-dark
    ">
      <Content />
    </div>
  </article>
</BaseLayout>
